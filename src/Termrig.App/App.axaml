<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Termrig.App.App"
             RequestedThemeVariant="Dark">
  
    <Application.Styles>
        <FluentTheme />
        <Style Selector="Window">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Background" Value="#0F141A"/>
        </Style>
        <Style Selector="Button">
            <Setter Property="Background" Value="#24303A"/>
            <Setter Property="Foreground" Value="#E6EDF3"/>
            <Setter Property="BorderBrush" Value="#3A4652"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style Selector="Button.compact">
            <Setter Property="Padding" Value="7,3"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="MinHeight" Value="24"/>
            <Setter Property="Background" Value="#202A33"/>
        </Style>
        <Style Selector="Button.icon">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="MinWidth" Value="24"/>
            <Setter Property="MinHeight" Value="24"/>
            <Setter Property="Background" Value="#202A33"/>
        </Style>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="#141B22"/>
            <Setter Property="Foreground" Value="#E6EDF3"/>
            <Setter Property="BorderBrush" Value="#35424F"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="Background" Value="#141B22"/>
            <Setter Property="Foreground" Value="#E6EDF3"/>
            <Setter Property="BorderBrush" Value="#35424F"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style Selector="ListBox">
            <Setter Property="Background" Value="#10161D"/>
            <Setter Property="Foreground" Value="#E6EDF3"/>
            <Setter Property="BorderBrush" Value="#283540"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style Selector="TabControl">
            <Setter Property="Background" Value="#0F141A"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style Selector="TabItem">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Background" Value="#151B22"/>
            <Setter Property="Foreground" Value="#E6EDF3"/>
            <Setter Property="BorderBrush" Value="#35424F"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="MinHeight" Value="24"/>
        </Style>
    </Application.Styles>
</Application>
