<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Termrig.App.App"
             RequestedThemeVariant="Dark">
  
    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://Avalonia.Controls.ColorPicker/Themes/Fluent/Fluent.xaml" />
        <Style Selector="Window">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Background" Value="#0F141A"/>
        </Style>
        <Style Selector="Button">
            <Setter Property="Background" Value="#24303A"/>
            <Setter Property="Foreground" Value="#E6EDF3"/>
            <Setter Property="BorderBrush" Value="#3A4652"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.compact">
            <Setter Property="Padding" Value="9,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="Background" Value="#202A33"/>
        </Style>
        <Style Selector="Button.icon">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="MinWidth" Value="28"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="Background" Value="#202A33"/>
        </Style>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="#141B22"/>
            <Setter Property="Foreground" Value="#E6EDF3"/>
            <Setter Property="BorderBrush" Value="#35424F"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="Background" Value="#141B22"/>
            <Setter Property="Foreground" Value="#E6EDF3"/>
            <Setter Property="BorderBrush" Value="#35424F"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style Selector="ListBox">
            <Setter Property="Background" Value="#10161D"/>
            <Setter Property="Foreground" Value="#E6EDF3"/>
            <Setter Property="BorderBrush" Value="#283540"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style Selector="ListBox.tabsTable">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="ListBox.tabsTable ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        </Style>
        <Style Selector="ListBox.tabsTable ListBoxItem /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
        </Style>
        <Style Selector="ListBox.tabsTable ListBoxItem:selected">
            <Setter Property="Background" Value="#203A50"/>
        </Style>
        <Style Selector="ListBox.tabsTable ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#203A50"/>
            <Setter Property="BorderBrush" Value="#58A6FF"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>
        <Style Selector="TabControl">
            <Setter Property="Background" Value="#0F141A"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style Selector="TabItem">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Background" Value="#151B22"/>
            <Setter Property="Foreground" Value="#E6EDF3"/>
            <Setter Property="BorderBrush" Value="#35424F"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="MinHeight" Value="24"/>
        </Style>
    </Application.Styles>
</Application>
