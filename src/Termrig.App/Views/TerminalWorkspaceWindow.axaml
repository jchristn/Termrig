<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Termrig.App.Views.TerminalWorkspaceWindow"
        Title="Termrig Workspace"
        Width="1200"
        Height="800"
        MinWidth="900"
        MinHeight="600">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#151B22" Padding="10,8">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock x:Name="TitleText" Grid.Column="0" Foreground="#FFFFFF" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="7" HorizontalAlignment="Right">
                    <Button x:Name="AddTabButton" Content="+" Classes="icon" ToolTip.Tip="Add tab"/>
                    <Button x:Name="EditTabButton" Content="Tab Settings" Classes="compact"/>
                    <Button x:Name="SaveProfileButton" Content="Save Profile" Classes="compact"/>
                </StackPanel>
            </Grid>
        </Border>
        <TabControl x:Name="TerminalTabs" Padding="0" FontSize="11"/>
    </DockPanel>
</Window>
