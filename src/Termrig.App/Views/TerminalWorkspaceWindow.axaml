<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Termrig.App.Views.TerminalWorkspaceWindow"
        Title="Termrig Workspace"
        Width="1200"
        Height="800"
        MinWidth="900"
        MinHeight="600">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#151B22" Padding="12">
            <DockPanel>
                <TextBlock x:Name="TitleText" DockPanel.Dock="Left" Foreground="#FFFFFF" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8">
                    <Button x:Name="AddTabButton" Content="+" Width="34" ToolTip.Tip="Add tab"/>
                    <Button x:Name="EditTabButton" Content="Tab settings"/>
                    <Button x:Name="SaveProfileButton" Content="Save profile"/>
                </StackPanel>
            </DockPanel>
        </Border>
        <TabControl x:Name="TerminalTabs" Padding="0" FontSize="12"/>
    </DockPanel>
</Window>
