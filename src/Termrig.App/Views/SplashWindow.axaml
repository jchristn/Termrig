<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Termrig.App.Views.SplashWindow"
        Icon="/Assets/termrig-logo.ico"
        Title="Termrig"
        Width="420"
        Height="360"
        CanResize="False"
        WindowDecorations="None"
        WindowStartupLocation="CenterScreen"
        Background="#0F141A">
    <Grid RowDefinitions="*,Auto" Margin="28">
        <StackPanel Grid.Row="0" Spacing="16" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Image Source="/Assets/termrig-logo.ico" Width="128" Height="128"/>
            <TextBlock Text="Termrig" Foreground="#FFFFFF" FontSize="28" FontWeight="SemiBold" HorizontalAlignment="Center"/>
        </StackPanel>

        <TextBlock Grid.Row="1"
                   Text="(c)2026 Joel Christner&#x0a;Licensed under the MIT license"
                   Foreground="#AAB6C2"
                   FontSize="12"
                   TextAlignment="Center"
                   HorizontalAlignment="Center"/>
    </Grid>
</Window>
