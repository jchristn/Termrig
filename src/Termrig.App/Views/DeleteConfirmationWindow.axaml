<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Termrig.App.Views.DeleteConfirmationWindow"
        Icon="/Assets/termrig-logo.ico"
        Title="Confirm delete"
        Width="460"
        Height="210"
        MinWidth="460"
        MinHeight="210"
        MaxWidth="460"
        MaxHeight="210"
        CanResize="False"
        WindowStartupLocation="CenterOwner">
    <Grid RowDefinitions="*,Auto" Margin="18">
        <StackPanel Grid.Row="0" Spacing="8">
            <TextBlock x:Name="HeadingText"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="#FFFFFF"/>
            <TextBlock x:Name="MessageText"
                       TextWrapping="Wrap"
                       Foreground="#C9D1D9"
                       LineHeight="18"/>
        </StackPanel>
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Spacing="8"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button x:Name="CancelButton" Content="Cancel" MinWidth="92"/>
            <Button x:Name="DeleteButton"
                    MinWidth="116"
                    Background="#8E2F2F"
                    BorderBrush="#D05A5A"/>
        </StackPanel>
    </Grid>
</Window>
