<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Termrig.App.Views.TextPromptWindow"
        Title="Prompt"
        Width="420"
        Height="180"
        MinWidth="360"
        MinHeight="160">
    <Grid RowDefinitions="*,Auto" Margin="16">
        <StackPanel Grid.Row="0" Spacing="8">
            <TextBlock x:Name="PromptText" FontWeight="SemiBold"/>
            <TextBox x:Name="ValueBox"/>
        </StackPanel>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button x:Name="CancelButton" Content="Cancel" MinWidth="84"/>
            <Button x:Name="SaveButton" Content="Save" MinWidth="84"/>
        </StackPanel>
    </Grid>
</Window>
