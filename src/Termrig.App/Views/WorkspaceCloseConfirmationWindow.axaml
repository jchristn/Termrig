<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Termrig.App.Views.WorkspaceCloseConfirmationWindow"
        Icon="/Assets/termrig-logo.ico"
        Title="Close workspace"
        Width="420"
        Height="188"
        MinWidth="420"
        MinHeight="188"
        MaxWidth="420"
        MaxHeight="188"
        CanResize="False"
        WindowStartupLocation="CenterOwner">
    <Grid RowDefinitions="*,Auto" Margin="18">
        <StackPanel Grid.Row="0" Spacing="8">
            <TextBlock Text="Close workspace?"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="#FFFFFF"/>
            <TextBlock x:Name="MessageText"
                       TextWrapping="Wrap"
                       Foreground="#C9D1D9"
                       LineHeight="18"/>
        </StackPanel>
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Spacing="8"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button x:Name="CancelButton" Content="Cancel" MinWidth="92"/>
            <Button x:Name="CloseWorkspaceButton"
                    Content="Close workspace"
                    MinWidth="128"
                    Background="#8E2F2F"
                    BorderBrush="#D05A5A"/>
        </StackPanel>
    </Grid>
</Window>
